{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Copy UF2 to Windows",
            "type": "shell",
            "command": "wsl",
            "args": [
                "-e", "bash", "-c",
                "cp ~/gui.ll/build/gui.ll.uf2 /mnt/c/temp"
            ],
            "options": {
                "cwd": "C:\\"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "close": true
            },
            "problemMatcher": []
        },
        {
            "label": "Build: Full RP2040",
            "type": "shell",
            "command": "wsl",
            "args": [
                "-e", "bash", "-c",
                "cd ~/gui.ll && rm -rf build && mkdir build && cd build && cmake .. -DPLATFORM_NAME=RP2040 && make"
            ],
            "options": {
                "cwd": "C:\\"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build: Full ESP32",
            "type": "shell",
            "command": "wsl",
            "args": [
                "-e", "bash", "-c",
                "source ~/esp-idf/export.sh && cd ~/gui.ll && rm -rf build && idf.py -DPLATFORM_NAME=ESP32 build"
            ],
            "options": {
                "cwd": "C:\\"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build: Incremental",
            "type": "shell",
            "command": "wsl",
            "args": [
                "-e", "bash", "-c",
                "cd ~/gui.ll/build && if [ -f build.ninja ]; then source ~/esp-idf/export.sh 2>/dev/null && ninja; else make; fi"
            ],
            "options": {
                "cwd": "C:\\"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Setup: ESP32 toolchain in WSL",
            "type": "shell",
            "command": "wsl",
            "args": [
                "-e", "bash", "-c", "~/gui.ll/Toolchain/ESP32/Setup.sh"
            ],
            "options": {
                "cwd": "C:\\"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Setup: RP2040 toolchain in WSL",
            "type": "shell",
            "command": "wsl",
            "args": [
                "-e", "bash", "-c", "$HOME/gui.ll/Toolchain/RP2040/Setup.sh"
            ],
            "options": {
                "cwd": "C:\\"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
